Command: build
Summary: Build xt_geoip data from the local CSV copy.
Flags: ["b", "c", "p", "f", "l"]

Command: conf
Summary: Configuration operations.
Usage: xtgeoip conf <FLAG>
Positional: "FLAG"
Constraints: Some(Constraints { exactly_one_positional: true })

Command: fetch
Summary: Download or refresh the local MaxMind CSV archive set.
Flags: ["p"]

Command: run
Summary: Fetch, then build, optionally wrapping with backup/clean/prune.
Flags: ["b", "c", "p", "f", "l"]

Command: version
Summary: Show the program version.
Flags: []

